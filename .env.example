# ── Payload CMS ──
DATABASE_URI=postgres://postgres:mypassword@postgres:5432/payload
PAYLOAD_SECRET=replace-with-a-secret
PORT=3000
NEXTJS_REVALIDATE_URL=http://localhost:4000/api/revalidate
NEXTJS_FRONTEND_URL=http://localhost:4000
REVALIDATE_SECRET_TOKEN=tokentokentoken
PREVIEW_SECRET=tokentokentoken
PAYLOAD_DOMAIN_URL=http://localhost:3000
NAME_BUSINESS=PATARUTERA

# ── Webhooks ──
USER_WEBHOOK_URL=http://quarkus-app-prod:8081/webhooks/payload
MEDUSA_WEBHOOK_URL=http://medusa-app:9000/webhooks/cms/sync-user
USER_WEBHOOK_SECRET=my-secure-webhook-secret
MEDUSA_WEBHOOK_SECRET=secret-webhook
MEDUSA_URL=http://medusa-app:9000

# ── RabbitMQ ──
RABBITMQ_URL=amqp://replace-with-rabbitmq-user:replace-with-rabbitmq-password@rabbitmq:5672
RABBITMQ_MAX_RETRIES=3
RABBITMQ_PREFETCH=10
RABBITMQ_RETRY_DELAY_MS=30000
RABBITMQ_DEFAULT_USER=replace-with-rabbitmq-user
RABBITMQ_DEFAULT_PASS=replace-with-rabbitmq-password
RABBITMQ_ERLANG_COOKIE=replace-with-a-long-random-cookie

# ── Observability ──
# Configuration follows Quarkus profile pattern: dev, test, prod
# Mode is determined by NODE_ENV (development/test/production)
# Each mode has sensible defaults; env vars override mode defaults

# ══════════════════════════════════════
# Common (applies to all modes)
# ══════════════════════════════════════
OTEL_SDK_DISABLED=false                    # Set 'true' to disable OTel SDK entirely
OTEL_SERVICE_NAME=tourism-events           # Overridden per mode below
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # Overridden per mode below
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=        # Override trace endpoint
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=       # Override metrics endpoint
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=          # Override logs endpoint (prod only)
OTEL_PROMETHEUS_PORT=9464                 # Direct /metrics endpoint port (like Quarkus micrometer.prometheus)
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=production

# ══════════════════════════════════════
# Dev mode (NODE_ENV=development) — matches Quarkus %dev
# ══════════════════════════════════════
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACES_SAMPLER_ARG=1.0               # 100% sampling
# OTEL_METRIC_EXPORT_INTERVAL=60000          # 60s
# LOG_LEVEL=debug

# ══════════════════════════════════════
# Test mode (NODE_ENV=test) — matches Quarkus %test
# ══════════════════════════════════════
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACES_SAMPLER_ARG=1.0               # 100% sampling
# OTEL_METRIC_EXPORT_INTERVAL=1000           # 1s (fast export for test reliability)
# LOG_LEVEL=info

# ══════════════════════════════════════
# Production mode (NODE_ENV=production) — matches Quarkus %prod
# ══════════════════════════════════════
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318  # Docker service name
# OTEL_TRACES_SAMPLER_ARG=0.1               # 10% sampling
# OTEL_METRIC_EXPORT_INTERVAL=60000          # 60s
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://otel-collector:4318/v1/logs
# LOG_LEVEL=info

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# ── Auth ──
AUTH_SECRET="replace-with-a-secret"
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=replace-with-keycloak-client-id
AUTH_KEYCLOAK_SECRET=replace-with-keycloak-client-secret
AUTH_KEYCLOAK_ISSUER=http://keycloak:8080/realms/quarkus
AUTH_KEYCLOAK_REALM=

NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_KEYCLOAK_ID=replace-with-keycloak-client-id
NEXT_PUBLIC_AUTH_KEYCLOAK_ISSUER=http://keycloak:8080/realms/quarkus

# ── S3 ──
S3_BUCKET=replace-with-bucket-name
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_REGION=us-east-1
